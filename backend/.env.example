# Dompetrack Backend Environment Variables
# Copy this file to .env and fill in your values

# Environment Mode (production / development)
# For production, set to: NODE_ENV=production
NODE_ENV=development

# Database — PostgreSQL connection string
# For production, set to your remote database: DATABASE_URL=postgresql://...
DATABASE_URL="postgresql://postgres:password@localhost:5432/dompetrack?schema=public"

# JWT Secrets — CHANGE THESE IN PRODUCTION!
# For production, use secure random strings (minimum 32 characters):
# JWT_ACCESS_SECRET=real_long_random_secret_min_32_chars
# JWT_REFRESH_SECRET=another_real_long_random_secret_min_32_chars
JWT_ACCESS_SECRET="dompetrack-access-secret-change-me-in-production"
JWT_REFRESH_SECRET="dompetrack-refresh-secret-change-me-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Server
PORT=3000
# For production, set to your frontend domain: FRONTEND_URL=https://domain-frontend-production
FRONTEND_URL="http://localhost:5173"

# Gemini AI Integration API Key
GEMINI_API_KEY=your_gemini_api_key_here
